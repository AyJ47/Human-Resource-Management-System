PORT=3000

# MongoDB Atlas connection string — replace with your own
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a strong random string in production (e.g. 64+ char hex)
JWT_SECRET=your_jwt_secret_here

# CORS origin — set to your frontend URL in production (e.g. https://your-app.vercel.app)
CORS_ORIGIN=*
